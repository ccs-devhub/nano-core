{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "jsx": "react-jsx",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@ccs-devhub/nano-core": ["src/lib/index.ts"],
            "@/*": ["src/*"],
            "@/misc/*": ["src/lib/misc/*"],
            "@/constants/*": ["src/lib/constants/*"],
            "@/commands/*": ["src/core/commands/*"],
            "@/events/*": ["src/core/events/*"],
            "@/snippets/*": ["src/lib/snippets/*"],
            "@/api/*": ["src/lib/api/*"],
            "@/registry/*": ["src/lib/registry/*"],
            "@/services/*": ["src/lib/services/*"],
            "@/store/*": ["src/lib/store/*"],
            "@/types/*": ["src/lib/types/*"]
        },
        "types": [
            "node"
        ]
    },
    "include": [
        "src",
        "tests",
        "modules"
    ],
    "exclude": [
        "dist"
    ]
}
